# Public URL of this Next.js app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend .NET API base URL (no trailing slash)
# Use the HTTP port from launchSettings.json to avoid local self-signed cert issues.
BACKEND_API_URL=http://localhost:5241

# JWT signing key — MUST match `jwt.Key` in ECommerce/appsettings.json.
# Used by middleware to verify the token signature.
JWT_SECRET=YourLongSecureSecretKeyHere1234567890

# Cookie name used for the JWT (default below is fine)
AUTH_COOKIE_NAME=auth_token
